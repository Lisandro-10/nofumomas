# node
NODE_ENV=

# ─── Firebase Client SDK (público, expuesto al browser) ───────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (privado, sólo server-side) ───────────────────────────
# Pegar el JSON del Service Account como una sola línea, o usar cada campo por separado.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Developers → Webhooks → Add endpoint → escuchar checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# developers.mercadopago.com → Tus aplicaciones → Credenciales → Access Token
MERCADOPAGO_ACCESS_TOKEN=
# developers.mercadopago.com → tu app → Webhooks → Configurar notificaciones → clave secreta
MERCADOPAGO_WEBHOOK_SECRET=
# URL pública donde MP envía las notificaciones de pago.
MERCADOPAGO_NOTIFICATION_URL=

# ─── Brevo (emails transaccionales) ───────────────────────────────────────────
# app.brevo.com → Configuración → Claves API → Generar nueva clave
BREVO_API_KEY=
# Email verificado en Brevo: app.brevo.com → Remitentes e IPs → Remitentes
BREVO_SENDER_EMAIL=lisandroandia14@gmail.com
BREVO_SENDER_NAME=No Fumo Más
# app.brevo.com → Campañas → Templates → (crear template) → copiar el ID numérico
BREVO_ACTIVATION_TEMPLATE_ID=
# app.brevo.com → Campañas → Templates → (crear template cuenta deshabilitada) → copiar el ID
BREVO_DISABLED_TEMPLATE_ID=
# app.brevo.com → Templates → (crear template reset password) → copiar el ID
BREVO_RESET_TEMPLATE_ID=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Secret para firmar tokens de activación (min. 32 caracteres aleatorios)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACTIVATION_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
# URL base de la app (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
